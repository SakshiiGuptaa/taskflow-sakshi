# Database
DB_HOST=db
DB_PORT=5432
DB_DATABASE=taskflow
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# Laravel
APP_KEY=base64:REPLACE_WITH_OUTPUT_OF_php_artisan_key_generate
APP_ENV=production
APP_DEBUG=false
APP_NAME=TaskFlow
APP_ENV=production
APP_URL=http://localhost:8000

# JWT
JWT_SECRET=REPLACE_WITH_A_RANDOM_SECRET

# Sessions
SESSION_DRIVER=database
SESSION_LIFETIME=120
BCRYPT_ROUNDS=12